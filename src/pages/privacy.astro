---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Privacy Policy - Gotwald Law, LLC" description="Privacy Policy for Gotwald Law, LLC.">
  <Header />
  <main class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <h1 class="text-4xl md:text-5xl font-bold font-serif text-[var(--color-forest-green)] mb-4">
          Privacy Policy
        </h1>
        <p class="text-sm text-gray-500 mb-8">Last Updated: March 2026</p>

        <p class="text-gray-700 leading-relaxed">
          Gotwald Law, LLC respects your privacy and is committed to protecting your personal information.
        </p>

        <h2 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mt-10 mb-4">
          Information We Collect
        </h2>
        <p class="text-gray-700 leading-relaxed">
          If you contact our firm through this website, we may collect information such as your name, phone number, email address, and any information you choose to provide.
        </p>

        <h2 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mt-10 mb-4">
          How We Use Information
        </h2>
        <p class="text-gray-700 leading-relaxed mb-2">We use this information to:</p>
        <ul class="list-disc list-inside text-gray-700 space-y-1 ml-4">
          <li>Respond to inquiries</li>
          <li>Communicate with clients and potential clients</li>
          <li>Provide legal services</li>
        </ul>
        <p class="text-gray-700 leading-relaxed mt-4">
          We do not sell or rent your personal information.
        </p>

        <h2 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mt-10 mb-4">
          Text Messaging (SMS)
        </h2>
        <p class="text-gray-700 leading-relaxed mb-2">
          If you provide your phone number and consent to receive text messages, we may send messages related to:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-1 ml-4">
          <li>Appointment reminders</li>
          <li>Case updates</li>
          <li>Client communication</li>
        </ul>
        <p class="text-gray-700 leading-relaxed mt-4">
          Message frequency may vary. Message and data rates may apply.
        </p>
        <p class="text-gray-700 leading-relaxed">
          You may opt out at any time by replying STOP.
        </p>

        <h2 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mt-10 mb-4">
          No Attorney-Client Relationship
        </h2>
        <p class="text-gray-700 leading-relaxed">
          Submitting information through this website does not create an attorney-client relationship.
        </p>

        <h2 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mt-10 mb-4">
          Contact
        </h2>
        <p class="text-gray-700 leading-relaxed">
          Gotwald Law, LLC<br />
          PO Box 26, Alpha, OH 45301<br />
          <a href="tel:937-303-7039" class="text-[var(--color-forest-green)] hover:text-[var(--color-gold)]">937-303-7039</a><br />
          <a href="mailto:kgotwaldlaw@gmail.com" class="text-[var(--color-forest-green)] hover:text-[var(--color-gold)]">kgotwaldlaw@gmail.com</a>
        </p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
