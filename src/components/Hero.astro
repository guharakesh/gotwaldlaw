---
// Hero section with headline and attorney photo
---

<section
  id="home"
  class="relative bg-[var(--color-forest-green)] text-white py-24 md:py-32 lg:py-40 overflow-hidden"
>
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/KristieHeader.jpg"
      alt="Kristie Gotwald, Attorney at Law"
      class="w-full h-full object-cover"
    />
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/30"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-2xl">
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold font-serif leading-tight mb-6"
      >
        Your Hometown Attorney — Fighting for Fairness and Protecting Your Rights
      </h1>

      <div class="text-xl md:text-2xl font-semibold text-[var(--color-gold)] mb-6">
        Fearless. Focused. Formidable.
      </div>

      <p class="text-lg md:text-xl text-gray-100 leading-relaxed mb-8">
        Every case is unique. Choose an attorney who understands what's at stake and will fight for what matters most to you.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#contact"
          class="bg-[var(--color-forest-green)] text-white px-8 py-4 rounded-md hover:bg-[var(--color-forest-green-dark)] transition-colors font-semibold text-center text-lg"
        >
          Schedule A Consultation
        </a>
        <a
          href="tel:937-303-7039"
          class="bg-[var(--color-gold)] text-white px-8 py-4 rounded-md hover:bg-[var(--color-gold-dark)] transition-colors font-semibold text-center text-lg"
        >
          Call Now
        </a>
      </div>
    </div>
  </div>
</section>
