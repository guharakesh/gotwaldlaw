---
// Hero section with headline and attorney photo
---

<section
  id="home"
  class="bg-[var(--color-forest-green)] text-white py-16 md:py-24"
>
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
      <!-- Left: Content -->
      <div class="space-y-6">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold font-serif leading-tight"
        >
          Your Family Attorney — Protecting Families and Fighting for Fairness
        </h1>

        <div class="text-xl md:text-2xl font-semibold text-[var(--color-gold)]">
          Fearless. Focused. Formidable.
        </div>

        <p class="text-lg text-gray-100 leading-relaxed">
          Every case is unique. The facts matter. The people matter. You matter.
          Hire someone that fights and knows what's at stake.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="#contact"
            class="bg-[var(--color-gold)] text-white px-8 py-4 rounded-md hover:bg-[var(--color-gold-dark)] transition-colors font-semibold text-center text-lg"
          >
            Schedule a Consultation
          </a>
          <a
            href="tel:937-303-7039"
            class="bg-white text-[var(--color-forest-green)] px-8 py-4 rounded-md hover:bg-gray-100 transition-colors font-semibold text-center text-lg"
          >
            Call Now
          </a>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="order-first md:order-last">
        <div class="relative">
          <img
            src="/suit.jpeg"
            alt="Kristie Gotwald, Attorney at Law"
            class="rounded-lg shadow-2xl w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
