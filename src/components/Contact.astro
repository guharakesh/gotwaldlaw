---
import ContactForm from './ContactForm';
---

<section id="contact" class="py-16 md:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-[var(--color-forest-green)] mb-4">
          Contact Us
        </h2>
        <p class="text-xl text-gray-600">
          Ready to discuss your case? Get in touch today.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Contact Information -->
        <div class="space-y-6">
          <div class="bg-white rounded-lg shadow-md p-6">
            <h3 class="text-xl font-bold font-serif text-[var(--color-forest-green)] mb-4">
              Gotwald Law, LLC
            </h3>

            <div class="space-y-4">
              <div class="flex items-start">
                <svg class="w-6 h-6 text-[var(--color-gold)] mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <div>
                  <p class="font-medium text-gray-900">Phone</p>
                  <a href="tel:937-303-7039" class="text-[var(--color-forest-green)] hover:text-[var(--color-gold)]">
                    937-303-7039
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <svg class="w-6 h-6 text-[var(--color-gold)] mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="font-medium text-gray-900">Email</p>
                  <a href="mailto:kgotwaldlaw@gmail.com" class="text-[var(--color-forest-green)] hover:text-[var(--color-gold)] break-all">
                    kgotwaldlaw@gmail.com
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <svg class="w-6 h-6 text-[var(--color-gold)] mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="font-medium text-gray-900">Address</p>
                  <p class="text-gray-600">
                    PO Box 26<br />
                    Alpha, OH 45301
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-[var(--color-forest-green)] text-white rounded-lg p-6">
            <h4 class="font-bold text-lg mb-2">Office Hours</h4>
            <p class="text-gray-100">
              Available by appointment<br />
              Emergency consultations available
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-xl font-bold font-serif text-[var(--color-forest-green)] mb-6">
            Send a Message
          </h3>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</section>
