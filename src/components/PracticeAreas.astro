---
// Practice Areas section with 4 practice area cards
const practiceAreas = [
  {
    title: "Criminal Defense",
    icon: "shield",
    items: [
      "Misdemeanors",
      "Felonies",
      "OVI",
      "Domestic Violence",
      "Traffic Offenses",
    ],
  },
  {
    title: "Family Law",
    icon: "scale",
    items: ["Custody", "Divorce", "Parenting Time", "Child Support"],
  },
  {
    title: "Juvenile Law",
    icon: "gavel",
    items: [
      "Delinquency Cases",
      "CPS Involvement",
      "Custody Matters",
      "Abuse Allegations",
      "Guardian ad Litem",
    ],
  },
  {
    title: "Personal Injury",
    icon: "medical",
    items: ["Auto Accidents", "Wrongful Death", "Dog Bites"],
  },
];

// SVG Icons
const icons: Record<string, string> = {
  shield: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
  </svg>`,
  scale: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
  </svg>`,
  gavel: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
  </svg>`,
  medical: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
  </svg>`,
};
---

<section id="practice-areas" class="py-16 md:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2
        class="text-4xl md:text-5xl font-bold font-serif text-[var(--color-forest-green)] mb-4"
      >
        Practice Areas
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Comprehensive legal representation across multiple areas of law
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        practiceAreas.map((area) => (
          <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition-shadow">
            <div
              class="w-16 h-16 mb-4 text-[var(--color-gold)]"
              set:html={icons[area.icon]}
            />

            <h3 class="text-2xl font-bold font-serif text-[var(--color-forest-green)] mb-3">
              {area.title}
            </h3>

            <p class="text-gray-600 mb-4">{area.description}</p>

            <ul class="space-y-2 mb-4">
              {area.items.map((item) => (
                <li class="text-sm text-gray-700 flex items-start">
                  <span class="text-[var(--color-gold)] mr-2">•</span>
                  {item}
                </li>
              ))}
            </ul>

            <p class="text-sm text-[var(--color-forest-green)] font-medium italic">
              {area.highlight}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
